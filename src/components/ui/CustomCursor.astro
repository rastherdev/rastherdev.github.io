---
// Custom cursor that follows mouse, changes on interactive elements
---

<div class="cursor" id="cursor" aria-hidden="true">
  <div class="cursor__dot" id="cursor-dot"></div>
  <div class="cursor__ring" id="cursor-ring"></div>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9998;
    pointer-events: none;
    mix-blend-mode: difference;
  }

  .cursor__dot {
    position: absolute;
    width: 6px;
    height: 6px;
    background: var(--color-text);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.2s, height 0.2s, background 0.2s;
  }

  .cursor__ring {
    position: absolute;
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--color-text);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    transition: width 0.3s, height 0.3s, border-color 0.3s;
  }

  /* Hover states */
  .cursor.is-hover .cursor__ring {
    width: 48px;
    height: 48px;
    border-color: var(--color-accent);
  }

  .cursor.is-hover .cursor__dot {
    background: var(--color-accent);
  }

  .cursor.is-clicking .cursor__ring {
    width: 24px;
    height: 24px;
    border-color: var(--color-accent);
  }

  /* Hide on touch devices */
  @media (hover: none) and (pointer: coarse) {
    .cursor {
      display: none;
    }
  }
</style>

<script>
  const dot = document.getElementById("cursor-dot")!;
  const ring = document.getElementById("cursor-ring")!;
  const cursor = document.getElementById("cursor")!;

  let mouseX = 0;
  let mouseY = 0;
  let ringX = 0;
  let ringY = 0;
  let isVisible = false;

  // Throttle mousemove
  document.addEventListener("mousemove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;
    if (!isVisible) {
      isVisible = true;
      cursor.style.opacity = "1";
    }
    // Dot follows immediately
    dot.style.left = `${mouseX}px`;
    dot.style.top = `${mouseY}px`;
  });

  // Ring follows with spring
  function animate() {
    ringX += (mouseX - ringX) * 0.15;
    ringY += (mouseY - ringY) * 0.15;
    ring.style.left = `${ringX}px`;
    ring.style.top = `${ringY}px`;
    requestAnimationFrame(animate);
  }
  animate();

  // Hide when leaving window
  document.addEventListener("mouseleave", () => {
    cursor.style.opacity = "0";
    isVisible = false;
  });

  document.addEventListener("mouseenter", () => {
    cursor.style.opacity = "1";
    isVisible = true;
  });

  // Hover states for interactive elements
  const interactiveSelectors = [
    "a",
    "button",
    "input",
    "textarea",
    "[role='button']",
    ".btn",
    ".nav__link",
    ".project-card",
    ".contact__card",
    ".skills__category",
    "[data-cursor-hover]",
  ];

  document.querySelectorAll(interactiveSelectors.join(",")).forEach((el) => {
    el.addEventListener("mouseenter", () => cursor.classList.add("is-hover"));
    el.addEventListener("mouseleave", () => cursor.classList.remove("is-hover"));
    el.addEventListener("mousedown", () => cursor.classList.add("is-clicking"));
    el.addEventListener("mouseup", () => cursor.classList.remove("is-clicking"));
  });

  // Also observe dynamically added elements
  const observer = new MutationObserver(() => {
    document.querySelectorAll(interactiveSelectors.join(",")).forEach((el) => {
      if (!(el as any).__cursorBound) {
        (el as any).__cursorBound = true;
        el.addEventListener("mouseenter", () => cursor.classList.add("is-hover"));
        el.addEventListener("mouseleave", () => cursor.classList.remove("is-hover"));
        el.addEventListener("mousedown", () => cursor.classList.add("is-clicking"));
        el.addEventListener("mouseup", () => cursor.classList.remove("is-clicking"));
      }
    });
  });

  observer.observe(document.body, { childList: true, subtree: true });
</script>
