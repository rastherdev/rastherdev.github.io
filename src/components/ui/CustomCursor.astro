---
// Custom cursor that follows mouse, changes on interactive elements
---

<div class="cursor" id="cursor" aria-hidden="true">
  <div class="cursor__dot" id="cursor-dot"></div>
  <div class="cursor__ring" id="cursor-ring"></div>
</div>

<style>
  .cursor {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 9998;
    pointer-events: none;
    mix-blend-mode: difference;
  }

  /* centering handled by GSAP (xPercent/yPercent) — GSAP owns transform */
  .cursor__dot {
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 6px;
    background: var(--color-text);
    border-radius: 50%;
    transition: width 0.2s, height 0.2s, background 0.2s;
    will-change: transform;
  }

  .cursor__ring {
    position: absolute;
    top: 0;
    left: 0;
    width: 32px;
    height: 32px;
    border: 1.5px solid var(--color-text);
    border-radius: 50%;
    transition: width 0.3s, height 0.3s, border-color 0.3s;
    will-change: transform;
  }

  /* Hover states */
  .cursor.is-hover .cursor__ring {
    width: 48px;
    height: 48px;
    border-color: var(--color-accent);
  }

  .cursor.is-hover .cursor__dot {
    background: var(--color-accent);
  }

  .cursor.is-clicking .cursor__ring {
    width: 24px;
    height: 24px;
    border-color: var(--color-accent);
  }

  /* Hide on touch devices */
  @media (hover: none) and (pointer: coarse) {
    .cursor {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  // Touch devices: cursor is hidden by CSS — skip ALL JS work too
  // (listeners, tweens and the MutationObserver would otherwise run for nothing)
  if (window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
    const dot = document.getElementById("cursor-dot")!;
    const ring = document.getElementById("cursor-ring")!;
    const cursor = document.getElementById("cursor")!;

    // Center via percent transforms; quickTo drives x/y (compositor-only —
    // the old left/top writes forced layout on every frame)
    gsap.set([dot, ring], { xPercent: -50, yPercent: -50 });

    const dotX = gsap.quickTo(dot, "x", { duration: 0.08, ease: "power2.out" });
    const dotY = gsap.quickTo(dot, "y", { duration: 0.08, ease: "power2.out" });
    const ringX = gsap.quickTo(ring, "x", { duration: 0.4, ease: "power3.out" });
    const ringY = gsap.quickTo(ring, "y", { duration: 0.4, ease: "power3.out" });

    let isVisible = false;

    document.addEventListener("mousemove", (e) => {
      dotX(e.clientX);
      dotY(e.clientY);
      ringX(e.clientX);
      ringY(e.clientY);
      if (!isVisible) {
        isVisible = true;
        cursor.style.opacity = "1";
      }
    });

    // Hide when leaving window
    document.addEventListener("mouseleave", () => {
      cursor.style.opacity = "0";
      isVisible = false;
    });

    document.addEventListener("mouseenter", () => {
      cursor.style.opacity = "1";
      isVisible = true;
    });

    // Hover states for interactive elements
    const interactiveSelectors = [
      "a",
      "button",
      "input",
      "textarea",
      "[role='button']",
      ".btn",
      ".nav__link",
      ".project-card",
      ".contact__card",
      ".skills__category",
      "[data-cursor-hover]",
    ].join(",");

    function bindHoverStates() {
      document.querySelectorAll(interactiveSelectors).forEach((el) => {
        if ((el as any).__cursorBound) return;
        (el as any).__cursorBound = true;
        el.addEventListener("mouseenter", () => cursor.classList.add("is-hover"));
        el.addEventListener("mouseleave", () => cursor.classList.remove("is-hover"));
        el.addEventListener("mousedown", () => cursor.classList.add("is-clicking"));
        el.addEventListener("mouseup", () => cursor.classList.remove("is-clicking"));
      });
    }

    bindHoverStates();

    // Also observe dynamically added elements
    const observer = new MutationObserver(bindHoverStates);
    observer.observe(document.body, { childList: true, subtree: true });
  }
</script>
