---
export interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  size?: "sm" | "md" | "lg";
  external?: boolean;
  download?: boolean | string;
}
---

<a
  href={Astro.props.href}
  class={`btn btn--${Astro.props.variant ?? "primary"} btn--${Astro.props.size ?? "md"}`}
  target={Astro.props.external ? "_blank" : undefined}
  rel={Astro.props.external ? "noopener noreferrer" : undefined}
  download={Astro.props.download ?? undefined}
>
  <slot />
</a>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-body);
    font-weight: 600;
    border: 1px solid transparent;
    border-radius: var(--border-radius);
    cursor: pointer;
    transition: all var(--transition-base);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
  }

  /* Sizes */
  .btn--sm { padding: 0.5rem 1rem; font-size: var(--text-sm); }
  .btn--md { padding: 0.75rem 1.5rem; font-size: var(--text-base); }
  .btn--lg { padding: 1rem 2rem; font-size: var(--text-lg); }

  /* Primary — accent filled */
  .btn--primary {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }
  .btn--primary:hover {
    background: transparent;
    color: var(--color-accent);
    box-shadow: var(--shadow-glow);
  }

  /* Secondary — outlined */
  .btn--secondary {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-border);
  }
  .btn--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    box-shadow: var(--shadow-glow);
  }

  /* Ghost — minimal */
  .btn--ghost {
    background: transparent;
    color: var(--color-text-muted);
    border-color: transparent;
  }
  .btn--ghost:hover {
    color: var(--color-accent);
    background: rgba(240, 160, 48, 0.08);
  }
</style>
