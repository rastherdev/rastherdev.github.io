---
import Badge from "./Badge.astro";
import type { Project } from "../../data/projects";
import type { ProjectsDict } from "../../i18n/types";

export interface Props {
  project: Project;
  dict: ProjectsDict;
  index: number;
}
---

<div
  class={`project-card${Astro.props.project.featured ? " project-card--featured" : ""}`}
  data-index={Astro.props.index}
>
  {Astro.props.project.featured && (
    <span class="project-card__flag">
      <i class="fa-solid fa-star" aria-hidden="true"></i>
      {Astro.props.dict.featuredBadge}
    </span>
  )}
  <div class="project-card__content">
    <div class="project-card__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <h3 class="project-card__name">{Astro.props.project.name}</h3>
    <p class="project-card__desc">{Astro.props.project.description}</p>

    <div class="project-card__stack">
      {Astro.props.project.stack.map((tech) => <Badge text={tech} />)}
    </div>

    <div class="project-card__actions">
      <a href={Astro.props.project.url} target="_blank" rel="noopener noreferrer" class="project-card__link">
        {Astro.props.dict.viewProject} ↗
      </a>
      <span class="project-card__link project-card__detail-hint" aria-hidden="true">
        {Astro.props.dict.gallery} +
      </span>
    </div>
  </div>
</div>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at top left, var(--color-accent-glow), transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  /* ── Featured (flagship) card ─────────────────────── */
  .project-card--featured {
    --beam-angle: 0deg;
    border-color: rgba(240, 160, 48, 0.25);
    box-shadow: 0 0 30px rgba(240, 160, 48, 0.06);
  }

  /* light beam orbiting the border (angle driven by GSAP) */
  .project-card--featured::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from var(--beam-angle),
      transparent 0%,
      transparent 70%,
      var(--color-accent) 86%,
      rgba(226, 226, 240, 0.9) 93%,
      transparent 100%
    );
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    pointer-events: none;
  }

  .project-card__flag {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    background: rgba(240, 160, 48, 0.08);
    border: 1px solid rgba(240, 160, 48, 0.3);
    border-radius: var(--border-radius-full);
    padding: 0.25em 0.8em;
    animation: flagPulse 2.4s ease-in-out infinite;
  }

  .project-card__flag i {
    font-size: 0.75em;
  }

  @keyframes flagPulse {
    0%, 100% { box-shadow: 0 0 0 rgba(240, 160, 48, 0); }
    50% { box-shadow: 0 0 16px rgba(240, 160, 48, 0.35); }
  }

  .project-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-card__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    opacity: 0.7;
  }

  .project-card__name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .project-card__desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    font-size: var(--text-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .project-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .project-card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .project-card__link:hover {
    color: var(--color-text);
  }

  .project-card__detail-hint {
    border: 1px solid var(--color-border);
    padding: 0.35em 0.9em;
    border-radius: var(--border-radius-full);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }

  .project-card:hover .project-card__detail-hint {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(240, 160, 48, 0.06);
  }
</style>

<script>
  function openModal(index: number) {
    const fn = (window as any).__openProjectModal;
    if (fn) {
      (window as any).__activeProjectIndex = index;
      fn();
    }
  }

  // Whole card opens the modal; the external link keeps its own behavior
  document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
    card.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) return;
      openModal(parseInt(card.dataset.index ?? "0"));
    });
  });
</script>
