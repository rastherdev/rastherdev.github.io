---
import Badge from "./Badge.astro";
import type { Project } from "../../data/projects";

export interface Props {
  project: Project;
  dict: {
    viewProject: string;
    viewCode: string;
    techStack: string;
    problem: string;
    solution: string;
    close: string;
  };
  index: number;
}
---

<div class="project-card" data-index={Astro.props.index}>
  <div class="project-card__content">
    <h3 class="project-card__name">{Astro.props.project.name}</h3>
    <p class="project-card__desc">{Astro.props.project.description}</p>

    <div class="project-card__stack">
      {Astro.props.project.stack.map((tech) => <Badge text={tech} />)}
    </div>

    <div class="project-card__actions">
      <a href={Astro.props.project.url} target="_blank" rel="noopener noreferrer" class="project-card__link">
        {Astro.props.dict.viewProject} ↗
      </a>
      {Astro.props.project.repoUrl && (
        <a href={Astro.props.project.repoUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">
          {Astro.props.dict.viewCode} ↗
        </a>
      )}
      <button class="project-card__link project-card__detail-btn" data-detail={Astro.props.index} type="button">
        More details ↓
      </button>
    </div>

    <!-- Expandable detail section -->
    <div class="project-card__detail" id={`project-detail-${Astro.props.index}`}>
      <div class="project-card__detail-section">
        <strong>{Astro.props.dict.problem}</strong>
        <p>{Astro.props.project.problem}</p>
      </div>
      <div class="project-card__detail-section">
        <strong>{Astro.props.dict.solution}</strong>
        <p>{Astro.props.project.solution}</p>
      </div>
      {Astro.props.project.snippet && (
        <div class="project-card__snippet">
          <pre><code>{Astro.props.project.snippet}</code></pre>
        </div>
      )}
    </div>
  </div>
</div>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-xl);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at top left, var(--color-accent-glow), transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card__content {
    position: relative;
    z-index: 1;
  }

  .project-card__name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .project-card__desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .project-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .project-card__link,
  .project-card__detail-btn {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
    background: none;
    border: none;
    cursor: pointer;
  }

  .project-card__link:hover,
  .project-card__detail-btn:hover {
    color: var(--color-text);
  }

  .project-card__detail {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms ease, margin-top 400ms ease, opacity 400ms ease;
    opacity: 0;
    margin-top: 0;
  }

  .project-card__detail.is-open {
    max-height: 800px;
    opacity: 1;
    margin-top: var(--space-xl);
  }

  .project-card__detail-section {
    margin-bottom: var(--space-lg);
  }

  .project-card__detail-section strong {
    display: block;
    font-family: var(--font-display);
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .project-card__detail-section p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .project-card__snippet {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    padding: var(--space-md);
    overflow-x: auto;
    margin-top: var(--space-md);
  }

  .project-card__snippet pre {
    margin: 0;
  }

  .project-card__snippet code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-code);
    line-height: 1.7;
  }
</style>

<script>
  // Toggle detail sections
  document.querySelectorAll<HTMLButtonElement>(".project-card__detail-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const index = btn.dataset.detail;
      const detail = document.getElementById(`project-detail-${index}`);
      if (detail) {
        const isOpen = detail.classList.toggle("is-open");
        btn.textContent = isOpen ? "Less details ↑" : "More details ↓";
      }
    });
  });
</script>
