---
import Badge from "./Badge.astro";
import type { Project } from "../../data/projects";

export interface Props {
  project: Project;
  dict: {
    viewProject: string;
    viewCode: string;
    techStack: string;
    problem: string;
    solution: string;
    close: string;
  };
  index: number;
}
---

<div class="project-card" data-index={Astro.props.index}>
  <div class="project-card__content">
    <div class="project-card__icon" aria-hidden="true">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
    </div>
    <h3 class="project-card__name">{Astro.props.project.name}</h3>
    <p class="project-card__desc">{Astro.props.project.description}</p>

    <div class="project-card__stack">
      {Astro.props.project.stack.map((tech) => <Badge text={tech} />)}
    </div>

    <div class="project-card__actions">
      <a href={Astro.props.project.url} target="_blank" rel="noopener noreferrer" class="project-card__link">
        {Astro.props.dict.viewProject} ↗
      </a>
      <button class="project-card__link project-card__detail-btn" data-detail={Astro.props.index} type="button">
        Quick View
      </button>
    </div>
  </div>
</div>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    position: relative;
    overflow: hidden;
    cursor: default;
    display: flex;
    flex-direction: column;
  }

  .project-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at top left, var(--color-accent-glow), transparent 70%);
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .project-card:hover {
    border-color: var(--color-border-hover);
    box-shadow: var(--shadow-md);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-card__icon {
    color: var(--color-accent);
    margin-bottom: var(--space-md);
    opacity: 0.7;
  }

  .project-card__name {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .project-card__desc {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    line-height: 1.7;
    font-size: var(--text-sm);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .project-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-lg);
  }

  .project-card__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    align-items: center;
  }

  .project-card__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .project-card__link:hover {
    color: var(--color-text);
  }

  .project-card__detail-btn {
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.35em 0.9em;
    border-radius: var(--border-radius-full);
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }

  .project-card__detail-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(240, 160, 48, 0.06);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".project-card__detail-btn").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      e.stopPropagation();
      const fn = (window as any).__openProjectModal;
      if (fn) {
        // Update modal content based on index
        const index = parseInt(btn.dataset.detail ?? "0");
        (window as any).__activeProjectIndex = index;
        fn();
      }
    });
  });
</script>
