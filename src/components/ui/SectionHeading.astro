---
export interface Props {
  tag?: "h2" | "h3";
  title: string;
  subtitle?: string;
}
---

<div class="section-heading">
  {Astro.props.tag === "h3" ? (
    <h3 class="section-heading__title">{Astro.props.title}</h3>
  ) : (
    <h2 class="section-heading__title">{Astro.props.title}</h2>
  )}
  {Astro.props.subtitle && (
    <p class="section-heading__subtitle">{Astro.props.subtitle}</p>
  )}
  <div class="section-heading__line" aria-hidden="true"></div>
</div>

<style>
  .section-heading {
    text-align: center;
    margin-bottom: var(--space-3xl);
    position: relative;
  }

  .section-heading__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .section-heading__subtitle {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 600px;
    margin-inline: auto;
  }

  .section-heading__line {
    width: 60px;
    height: 3px;
    background: var(--color-accent);
    margin: var(--space-lg) auto 0;
    border-radius: var(--border-radius-full);
  }
</style>
