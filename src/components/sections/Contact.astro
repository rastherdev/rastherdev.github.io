---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { socialLinks, resumeUrl } from "../../data/social";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="contact section section--band" id="contact">
      <div class="section__inner">
        <SectionHeading title={dict.contact.heading} subtitle={dict.contact.subtitle} />

        <p class="contact__status">
          <span class="contact__status-dot" aria-hidden="true"></span>
          {dict.contact.status}
        </p>

        <div class="contact__grid">
          <a href={`mailto:${socialLinks[0].url.replace("mailto:", "")}`} class="contact__card">
            <div class="contact__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            </div>
            <span class="contact__card-label">{dict.contact.emailLabel}</span>
            <span class="contact__card-value">rastherdev@gmail.com</span>
          </a>

          <a href={socialLinks[1].url} target="_blank" rel="noopener noreferrer" class="contact__card">
            <div class="contact__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </div>
            <span class="contact__card-label">{dict.contact.linkedinLabel}</span>
            <span class="contact__card-value">linkedin.com/in/rastherdev</span>
          </a>

          <a href={socialLinks[2].url} target="_blank" rel="noopener noreferrer" class="contact__card">
            <div class="contact__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </div>
            <span class="contact__card-label">{dict.contact.githubLabel}</span>
            <span class="contact__card-value">github.com/rastherdev</span>
          </a>

          <a href={resumeUrl} class="contact__card" download>
            <div class="contact__card-icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
            </div>
            <span class="contact__card-label">{dict.contact.cvLabel}</span>
            <span class="contact__card-value">resume.pdf</span>
          </a>
        </div>
      </div>
    </section>
  );
})()}

<style>
  .contact__status {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    width: fit-content;
    margin: 0 auto var(--space-2xl);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    background: rgba(77, 212, 192, 0.05);
    border: 1px solid rgba(77, 212, 192, 0.2);
    border-radius: var(--border-radius-full);
    padding: 0.45em 1.2em;
  }

  .contact__status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #3ddc84;
    position: relative;
    flex-shrink: 0;
  }

  .contact__status-dot::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #3ddc84;
    animation: statusPing 2s ease-out infinite;
  }

  @keyframes statusPing {
    0% { transform: scale(1); opacity: 0.7; }
    70%, 100% { transform: scale(3); opacity: 0; }
  }

  .contact__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-lg);
  }

  .contact__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    text-align: center;
    text-decoration: none;
    transition: border-color var(--transition-base), box-shadow var(--transition-base),
      transform var(--transition-base);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    position: relative;
    overflow: hidden;
  }

  .contact__card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at center, var(--color-accent-glow), transparent 80%);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .contact__card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-4px);
  }

  .contact__card:hover::before {
    opacity: 1;
  }

  /* accent line unfolds along the base — restrained highlight */
  .contact__card::after {
    content: "";
    position: absolute;
    left: 18%;
    right: 18%;
    bottom: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
    transform: scaleX(0);
    transition: transform var(--transition-slow);
  }

  .contact__card:hover::after {
    transform: scaleX(1);
  }

  .contact__card-icon {
    color: var(--color-accent);
    position: relative;
    z-index: 1;
  }

  .contact__card-label {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    font-size: var(--text-lg);
    position: relative;
    z-index: 1;
  }

  .contact__card-value {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    position: relative;
    z-index: 1;
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".contact",
        start: "top 75%",
      },
    });

    tl.from(".contact .section-heading__title", {
      opacity: 0,
      y: 20,
      duration: 0.6,
      ease: "power3.out",
    })
      .from(
        ".contact .section-heading__subtitle",
        { opacity: 0, y: 10, duration: 0.5, ease: "power3.out" },
        "-=0.2"
      )
      .from(
        ".contact .section-heading__line",
        { scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out" },
        "-=0.2"
      )
      .from(
        ".contact__status",
        { opacity: 0, scale: 0.85, duration: 0.5, ease: "back.out(2)" },
        "-=0.2"
      )
      .from(
        ".contact__card",
        {
          opacity: 0,
          y: 40,
          scale: 0.92,
          stagger: 0.1,
          duration: 0.55,
          ease: "back.out(1.7)",
        },
        "-=0.1"
      );

  });
</script>
