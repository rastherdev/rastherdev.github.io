---
import SectionHeading from "../ui/SectionHeading.astro";
import Card from "../ui/Card.astro";
import ProjectModal from "../ui/ProjectModal.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { projects } from "../../data/projects";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="projects section" id="projects">
      <div class="section__inner">
        <SectionHeading title={dict.projects.heading} />

        <div class="projects__grid">
          {projects.map((project, i) => (
            <Card project={project} dict={dict.projects} index={i} />
          ))}
        </div>
      </div>

      <!-- Shared modal — content updated dynamically via JS -->
      <div id="project-modals" style="display:none" aria-hidden="true">
        {projects.map((project, i) => (
          <div data-project-index={i}>
            <ProjectModal project={project} dict={dict.projects} />
          </div>
        ))}
      </div>
    </section>
  );
})()}

<style>
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: var(--space-xl);
  }

  @media (max-width: 768px) {
    .projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      scrollTrigger: { trigger: ".projects", start: "top 70%" },
    });

    tl.from(".projects .section-heading__title", {
      opacity: 0, y: 20, duration: 0.6, ease: "power3.out",
    })
      .from(".projects .section-heading__line", {
        scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out",
      }, "-=0.2")
      .from(".project-card", {
        opacity: 0, y: 50, scale: 0.96, stagger: 0.15, duration: 0.7, ease: "power3.out",
      }, "-=0.1");

    // Flagship card: light beam orbits the border
    gsap.to(".project-card--featured", {
      "--beam-angle": "360deg",
      duration: 5,
      repeat: -1,
      ease: "none",
    });
  });

  // Hover microinteraction
  document.querySelectorAll<HTMLElement>(".project-card").forEach((card) => {
    card.addEventListener("mouseenter", () => {
      gsap.to(card, {
        y: -6, scale: 1.02,
        boxShadow: "0 12px 40px rgba(240, 160, 48, 0.12)",
        borderColor: "var(--color-accent)",
        duration: 0.35, ease: "power2.out",
      });
    });
    card.addEventListener("mouseleave", () => {
      gsap.to(card, {
        y: 0, scale: 1,
        boxShadow: "var(--shadow-md)",
        borderColor: "var(--color-border)",
        duration: 0.35, ease: "power2.out",
      });
    });
  });

  // Modal logic: extract modals from hidden container, show correct one
  const modalsContainer = document.getElementById("project-modals")!;
  const modals = modalsContainer.querySelectorAll<HTMLElement>("[data-project-index]");

  // Move modals to body for proper stacking
  modals.forEach((m) => document.body.appendChild(m));

  // Override global opener
  (window as any).__openProjectModal = () => {
    const idx = (window as any).__activeProjectIndex ?? 0;
    modals.forEach((m) => {
      const overlay = m.querySelector<HTMLElement>(".modal-overlay")!;
      const isTarget = parseInt(m.dataset.projectIndex ?? "0") === idx;
      if (isTarget) {
        overlay.classList.add("is-open");
        overlay.setAttribute("aria-hidden", "false");
        document.body.style.overflow = "hidden";
        // Pause ScrollSmoother so the page doesn't scroll behind the modal
        (window as any).__smoother?.paused(true);

        // Staggered content entrance
        gsap.fromTo(
          overlay.querySelectorAll(".modal__body > *"),
          { opacity: 0, y: 18 },
          { opacity: 1, y: 0, stagger: 0.07, duration: 0.45, ease: "power2.out", delay: 0.1 }
        );
      }
    });
  };

  // Close all modals
  function closeAllModals() {
    modals.forEach((m) => {
      const overlay = m.querySelector<HTMLElement>(".modal-overlay")!;
      overlay.classList.remove("is-open");
      overlay.setAttribute("aria-hidden", "true");
    });
    document.body.style.overflow = "";
    (window as any).__smoother?.paused(false);
  }

  // Wire close buttons, overlay clicks & gallery thumbnails
  modals.forEach((m) => {
    const overlay = m.querySelector<HTMLElement>(".modal-overlay")!;
    const closeBtn = m.querySelector<HTMLElement>(".modal__close");
    closeBtn?.addEventListener("click", closeAllModals);
    overlay.addEventListener("click", (e) => {
      if (e.target === overlay) closeAllModals();
    });

    // Gallery: thumbnail click crossfades the main image
    const mainImg = m.querySelector<HTMLImageElement>(".modal__gallery-img");
    m.querySelectorAll<HTMLElement>(".modal__thumb").forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const src = thumb.dataset.src;
        if (!mainImg || !src || mainImg.getAttribute("src") === src) return;
        m.querySelector(".modal__thumb.is-active")?.classList.remove("is-active");
        thumb.classList.add("is-active");
        mainImg.setAttribute("src", src);
        gsap.fromTo(
          mainImg,
          { opacity: 0.15, scale: 1.04 },
          { opacity: 1, scale: 1, duration: 0.4, ease: "power2.out" }
        );
      });
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAllModals();
  });
</script>
