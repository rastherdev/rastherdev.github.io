---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { skillCategories } from "../../data/skills";

interface Props {
  locale: "en" | "es";
}

// FontAwesome icon mapping: tech name → FA class
const faIcons: Record<string, string> = {
  php: "fa-brands fa-php",
  typescript: "fa-brands fa-js",
  javascript: "fa-brands fa-js",
  python: "fa-brands fa-python",
  sql: "fa-solid fa-database",
  laravel: "fa-brands fa-laravel",
  vue: "fa-brands fa-vuejs",
  react: "fa-brands fa-react",
  angular: "fa-brands fa-angular",
  express: "fa-brands fa-node-js",
  bootstrap: "fa-brands fa-bootstrap",
  postgresql: "fa-solid fa-server",
  mysql: "fa-solid fa-database",
  redis: "fa-solid fa-bolt",
  sqlite: "fa-solid fa-hard-drive",
  docker: "fa-brands fa-docker",
  aws: "fa-brands fa-aws",
  gcp: "fa-brands fa-google",
  digitalocean: "fa-brands fa-digital-ocean",
  github: "fa-brands fa-github",
  nginx: "fa-solid fa-server",
  git: "fa-brands fa-git-alt",
  phpunit: "fa-solid fa-vial",
  pest: "fa-solid fa-bug",
  postman: "fa-solid fa-paper-plane",
  vscode: "fa-solid fa-code",
  linux: "fa-brands fa-linux",
  repository: "fa-solid fa-boxes-stacked",
  factory: "fa-solid fa-industry",
  observer: "fa-solid fa-eye",
  singleton: "fa-solid fa-cube",
};

const categoryIcons: Record<string, string> = {
  languages: "fa-solid fa-code",
  frameworks: "fa-solid fa-cubes",
  databases: "fa-solid fa-database",
  devops: "fa-solid fa-cloud",
  patterns: "fa-solid fa-diagram-project",
  tools: "fa-solid fa-toolbox",
};

function toFaIcon(name: string): string {
  const key = name.toLowerCase().replace(/[^a-z0-9]/g, "");
  return faIcons[key] ?? "fa-solid fa-gear";
}

// Two marquee rows (odd/even split), scrolling in opposite directions
const allSkills = skillCategories.flatMap((c) => c.items.map((s) => s.name));
const marqueeRows = [
  allSkills.filter((_, i) => i % 2 === 0),
  allSkills.filter((_, i) => i % 2 === 1),
];
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="skills section" id="skills">
      <div class="section__inner">
        <SectionHeading title={dict.skills.heading} />

        <!-- Infinite marquee: content duplicated per row for a seamless -50% loop -->
        <div class="skills__marquee" aria-hidden="true">
          {marqueeRows.map((row) => (
            <div class="skills__marquee-row">
              {[0, 1].map(() => (
                <div class="skills__marquee-group">
                  {row.map((name) => (
                    <span class="skills__mchip">
                      <i class={toFaIcon(name)}></i>
                      {name}
                    </span>
                  ))}
                </div>
              ))}
            </div>
          ))}
        </div>

        <div class="skills__grid">
          {dict.skills.categories.map((cat, i) => {
            const data = skillCategories.find((s) => s.key === cat.key);
            if (!data) return null;
            return (
              <div class="skills__card" style={`--delay:${i}`}>
                <h3 class="skills__card-title">
                  <i class={`${categoryIcons[cat.key] ?? "fa-solid fa-folder"} skills__cat-icon`}></i>
                  {cat.label}
                </h3>
                <ul class="skills__list">
                  {data.items.map((skill) => (
                    <li class="skills__item" data-level={skill.level}>
                      <div class="skills__item-header">
                        <i class={`${toFaIcon(skill.name)} skills__item-icon`}></i>
                        <span class="skills__item-name">{skill.name}</span>
                        <span class="skills__item-pct">{skill.level}%</span>
                      </div>
                      <div class="skills__bar">
                        <div class="skills__bar-fill"></div>
                      </div>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  );
})()}

<style>
  /* ── Marquee ─────────────────────────────────────────── */
  .skills__marquee {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    overflow: hidden;
    margin-bottom: var(--space-2xl);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
  }

  .skills__marquee-row {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .skills__marquee-group {
    display: flex;
    gap: var(--space-md);
    padding-right: var(--space-md);
  }

  .skills__mchip {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-full);
    padding: 0.45em 1.1em;
    white-space: nowrap;
    transition: border-color 0.25s, color 0.25s, box-shadow 0.25s;
  }

  .skills__mchip i {
    color: var(--color-code);
  }

  .skills__mchip:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    box-shadow: 0 0 14px var(--color-accent-glow);
  }

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-xl);
    perspective: 1000px;
  }

  .skills__card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-xl);
    transition: border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .skills__card:hover {
    border-color: var(--color-border-hover);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
  }

  .skills__card-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-accent);
    margin-bottom: var(--space-lg);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* Category icon */
  .skills__cat-icon {
    width: 20px;
    font-size: var(--text-base);
    color: var(--color-accent);
  }

  .skills__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .skills__item-header {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: 4px;
  }

  .skills__item-icon {
    width: 18px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-align: center;
  }

  .skills__item-name {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex: 1;
  }

  .skills__item-pct {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .skills__bar {
    height: 4px;
    background: var(--color-border);
    border-radius: 2px;
    overflow: hidden;
  }

  .skills__bar-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-code));
    border-radius: 2px;
  }

  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      scrollTrigger: { trigger: ".skills", start: "top 68%", once: true },
    });

    tl.from(".skills .section-heading__title", {
      opacity: 0, y: 20, duration: 0.6, ease: "power3.out",
    })
      .from(".skills .section-heading__line", {
        scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out",
      }, "-=0.2")
      .from(".skills__marquee", {
        opacity: 0, y: 20, duration: 0.6, ease: "power2.out",
      }, "-=0.2")
      // Cards flip in from a slight 3D tilt
      .from(".skills__card", {
        opacity: 0, y: 40, rotationX: -14, transformOrigin: "center top",
        stagger: 0.1, duration: 0.7, ease: "power3.out",
      }, "-=0.3");

    // ── Marquee: two rows, opposite directions, slow on hover ──
    const marqueeTweens: gsap.core.Tween[] = [];
    document.querySelectorAll<HTMLElement>(".skills__marquee-row").forEach((row, i) => {
      const reverse = i % 2 === 1;
      const tween = gsap.fromTo(
        row,
        { xPercent: reverse ? -50 : 0 },
        { xPercent: reverse ? 0 : -50, duration: 28 + i * 6, repeat: -1, ease: "none" }
      );
      marqueeTweens.push(tween);
      row.addEventListener("mouseenter", () => gsap.to(tween, { timeScale: 0.15, duration: 0.5 }));
      row.addEventListener("mouseleave", () => gsap.to(tween, { timeScale: 1, duration: 0.5 }));
    });

    // No point ticking the marquee while Skills is off-screen
    const marquee = document.querySelector(".skills__marquee");
    if (marquee) {
      new IntersectionObserver((entries) =>
        entries.forEach((entry) =>
          marqueeTweens.forEach((t) => (entry.isIntersecting ? t.play() : t.pause()))
        )
      ).observe(marquee);
    }

    // ── Bars fill + percentages count up ───────────────────
    // ONE ScrollTrigger per card (not two per skill — that was ~54 triggers
    // evaluated on every scroll frame); inner tweens fire plain on enter.
    document.querySelectorAll<HTMLElement>(".skills__card").forEach((card) => {
      ScrollTrigger.create({
        trigger: card,
        start: "top 78%",
        once: true,
        onEnter: () => {
          card.querySelectorAll<HTMLElement>(".skills__item").forEach((item, i) => {
            const level = parseInt(item.dataset.level ?? "0");
            const bar = item.querySelector(".skills__bar-fill");
            const pct = item.querySelector(".skills__item-pct");

            gsap.fromTo(bar, { width: "0%" }, {
              width: `${level}%`, duration: 1.2, ease: "power3.out", delay: i * 0.08,
            });

            const state = { v: 0 };
            gsap.to(state, {
              v: level, duration: 1.2, ease: "power3.out", delay: i * 0.08,
              onUpdate: () => {
                if (pct) pct.textContent = `${Math.round(state.v)}%`;
              },
            });
          });
        },
      });
    });
  });

  // Hover effect (subtle — the old scale(1.10) jumped too hard)
  document.querySelectorAll<HTMLElement>(".skills__card").forEach((card) => {
    card.addEventListener("mouseenter", () => {
      gsap.to(card, {
        scale: 1.03,
        y: -5,
        boxShadow: "0 12px 35px rgba(240, 160, 48, 0.15)",
        borderColor: "var(--color-accent)",
        duration: 0.35,
        ease: "power2.out",
      });
    });
    card.addEventListener("mouseleave", () => {
      gsap.to(card, {
        scale: 1,
        y: 0,
        boxShadow: "0 4px 20px rgba(0,0,0,0.25)",
        borderColor: "var(--color-border)",
        duration: 0.35,
        ease: "power2.out",
      });
    });
  });
</script>
