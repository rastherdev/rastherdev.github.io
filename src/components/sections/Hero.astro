---
import Button from "../ui/Button.astro";
import Terminal from "../ui/Terminal.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { resumeUrl } from "../../data/social";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="hero" id="top">
      <div class="hero__inner">
        <!-- Left: personal info -->
        <div class="hero__content" id="hero-content">
          <p class="hero__greeting">{dict.hero.greeting}</p>
          <h1 class="hero__name">
            <span class="hero__name-line">Giovany</span>
            <span class="hero__name-line">Domínguez</span>
          </h1>
          <div class="hero__title-row">
            <p class="hero__title">{dict.hero.title}</p>
            <span class="hero__title-bar"></span>
          </div>
          <p class="hero__tagline">{dict.hero.tagline}</p>
          <div class="hero__ctas">
            <Button href="#projects" variant="primary" size="lg">
              {dict.hero.viewProjects}
            </Button>
            <Button href={resumeUrl} variant="secondary" size="lg" download={true}>
              {dict.hero.downloadCv}
            </Button>
          </div>
          <div class="hero__stats">
            <div class="hero__stat">
              <span class="hero__stat-number">3+</span>
              <span class="hero__stat-label">{dict.about.quickFacts[1].label}</span>
            </div>
            <div class="hero__stat-divider"></div>
            <div class="hero__stat">
              <span class="hero__stat-number">2</span>
              <span class="hero__stat-label">SaaS Platforms</span>
            </div>
            <div class="hero__stat-divider"></div>
            <div class="hero__stat">
              <span class="hero__stat-number">25+</span>
              <span class="hero__stat-label">{dict.hero.statTech}</span>
            </div>
          </div>
        </div>

        <!-- Right: interactive terminal -->
        <div class="hero__terminal-wrapper" id="hero-terminal">
          <Terminal lines={dict.hero.terminalLines} locale={Astro.props.locale} />
        </div>
      </div>

      <div class="hero__bg" aria-hidden="true">
        <div class="hero__grid" data-speed="0.3"></div>
        <div class="hero__glow hero__glow--1" data-speed="0.6"></div>
        <div class="hero__glow hero__glow--2" data-speed="0.4"></div>
      </div>

      <div class="hero__scroll-indicator" aria-hidden="true">
        <span class="hero__scroll-line"></span>
      </div>
    </section>
  );
})()}

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-block: calc(var(--nav-height) + var(--space-3xl)) var(--space-3xl);
  }

  /* 2-column grid on desktop */
  .hero__inner {
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(var(--space-2xl), 5vw, var(--space-4xl));
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.02em;
  }

  .hero__name {
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: var(--space-md);
    letter-spacing: -0.03em;
    line-height: 1.05;
    display: flex;
    flex-direction: column;
  }

  .hero__name-line {
    display: block;
    color: var(--color-accent);
    /* Oversized gradient: hover animates background-position (tween-able),
       never background-image (GSAP can't interpolate gradients) */
    background: linear-gradient(
      120deg,
      var(--color-text) 0%,
      var(--color-text) 15%,
      var(--color-accent) 35%,
      var(--color-code) 50%,
      var(--color-accent) 65%,
      var(--color-text) 85%,
      var(--color-text) 100%
    );
    background-size: 250% 100%;
    background-position: 0% 0%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--color-code);
    white-space: nowrap;
  }

  .hero__title-bar {
    display: block;
    height: 1px;
    flex: 1;
    background: linear-gradient(90deg, var(--color-border), transparent);
    min-width: 30px;
  }

  .hero__tagline {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-xl);
    max-width: 460px;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .hero__stats {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
  }

  .hero__stat-number {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.2;
  }

  .hero__stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .hero__stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border);
    flex-shrink: 0;
  }

  .hero__terminal-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Background */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero__grid {
    position: absolute;
    inset: -20%;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.1;
    mask-image: radial-gradient(ellipse 70% 60% at center, black 25%, transparent 70%);
  }

  /* soft glows as radial gradients — visually a blurred disc, but painted
     once; filter: blur(140px) + data-speed parallax repainted a huge blurred
     layer on every scroll frame */
  .hero__glow {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
  }

  .hero__glow--1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(closest-side, var(--color-accent) 0%, var(--color-accent) 30%, transparent 100%);
    top: -150px;
    right: -100px;
  }

  .hero__glow--2 {
    width: 450px;
    height: 450px;
    background: radial-gradient(closest-side, var(--color-code) 0%, var(--color-code) 30%, transparent 100%);
    bottom: -100px;
    left: 10%;
  }

  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { transform: translateY(-100%); }
    50% { transform: translateY(100%); }
  }

  /* Mobile: stack vertically */
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .hero__content {
      order: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .hero__terminal-wrapper {
      order: 2;
    }

    .hero__tagline {
      max-width: 100%;
    }

    .hero__ctas {
      justify-content: center;
    }

    .hero__title-row {
      justify-content: center;
    }

    .hero__stats {
      justify-content: center;
    }

    .hero__name {
      align-items: center;
    }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      delay: 0.1,
    });

    // Terminal slides in from right
    tl.from("#hero-terminal", {
      opacity: 0,
      x: 60,
      scale: 0.96,
      duration: 0.8,
    })
      // Content slides in from left
      .from(
        "#hero-content",
        { opacity: 0, x: -40, duration: 0.8 },
        "-=0.6"
      )
      // Stagger children
      .from(
        "#hero-content > *",
        { opacity: 0, y: 20, stagger: 0.08, duration: 0.5 },
        "-=0.4"
      )
      // Stats pop
      .from(
        ".hero__stat",
        {
          opacity: 0,
          y: 15,
          scale: 0.9,
          stagger: 0.1,
          duration: 0.4,
          ease: "back.out(2)",
        },
        "-=0.2"
      );

    // Scroll indicator fade
    gsap.to(".hero__scroll-indicator", {
      opacity: 0,
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: 0.3,
      },
    });

    // Name gradient sweep on hover — a color wave crosses the letters
    const nameEl = document.querySelector<HTMLElement>(".hero__name");
    if (nameEl) {
      const lines = nameEl.querySelectorAll<HTMLElement>(".hero__name-line");
      nameEl.addEventListener("mouseenter", () => {
        gsap.to(lines, {
          backgroundPosition: "100% 0%",
          duration: 0.9,
          stagger: 0.12,
          ease: "power2.inOut",
        });
      });
      nameEl.addEventListener("mouseleave", () => {
        gsap.to(lines, {
          backgroundPosition: "0% 0%",
          duration: 0.9,
          stagger: 0.12,
          ease: "power2.inOut",
        });
      });
    }
  });
</script>
