---
import Button from "../ui/Button.astro";
import Terminal from "../ui/Terminal.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { resumeUrl } from "../../data/social";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="hero" id="top">
      <div class="hero__inner">
        <div class="hero__terminal-wrapper" id="hero-terminal">
          <Terminal lines={dict.hero.terminalLines} />
        </div>

        <div class="hero__content" id="hero-content">
          <p class="hero__greeting">{dict.hero.greeting}</p>
          <h1 class="hero__name">{dict.hero.name}</h1>
          <p class="hero__title">{dict.hero.title}</p>
          <p class="hero__tagline">{dict.hero.tagline}</p>

          <div class="hero__ctas">
            <Button href="#projects" variant="primary" size="lg">
              {dict.hero.viewProjects}
            </Button>
            <Button href={resumeUrl} variant="secondary" size="lg" download={true}>
              {dict.hero.downloadCv}
            </Button>
          </div>
        </div>
      </div>

      <!-- Background decorative elements with parallax -->
      <div class="hero__bg" aria-hidden="true">
        <div class="hero__grid" data-speed="0.3"></div>
        <div class="hero__glow hero__glow--1" data-speed="0.6"></div>
        <div class="hero__glow hero__glow--2" data-speed="0.4"></div>
      </div>

      <!-- Scroll indicator -->
      <div class="hero__scroll-indicator" aria-hidden="true">
        <span class="hero__scroll-line"></span>
      </div>
    </section>
  );
})()}

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding-block: calc(var(--nav-height) + var(--space-4xl)) var(--space-4xl);
  }

  .hero__inner {
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3xl);
    position: relative;
    z-index: 2;
  }

  .hero__terminal-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    /* Natural state is visible — GSAP from() adds entrance drama */
  }

  .hero__content {
    text-align: center;
    max-width: 700px;
    /* Natural state is visible — no opacity: 0 */
  }

  .hero__greeting {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero__name {
    font-size: var(--text-4xl);
    font-weight: 700;
    margin-bottom: var(--space-xs);
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero__title {
    font-family: var(--font-mono);
    font-size: var(--text-xl);
    color: var(--color-code);
    margin-bottom: var(--space-lg);
  }

  .hero__tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
    margin-bottom: var(--space-2xl);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    justify-content: center;
  }

  /* Background decoration */
  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .hero__grid {
    position: absolute;
    inset: -20%;
    background-image:
      linear-gradient(var(--color-border) 1px, transparent 1px),
      linear-gradient(90deg, var(--color-border) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.1;
    mask-image: radial-gradient(ellipse 70% 60% at center, black 25%, transparent 70%);
  }

  .hero__glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.1;
  }

  .hero__glow--1 {
    width: 700px;
    height: 700px;
    background: var(--color-accent);
    top: -250px;
    right: -150px;
  }

  .hero__glow--2 {
    width: 500px;
    height: 500px;
    background: var(--color-code);
    bottom: -150px;
    left: -100px;
  }

  /* Scroll indicator */
  .hero__scroll-indicator {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 40px;
    background: var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: var(--color-accent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { transform: translateY(-100%); }
    50% { transform: translateY(100%); }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  // Entrance animation — uses from() so natural CSS state is visible
  // If GSAP fails to load, content remains fully visible
  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      defaults: { ease: "power3.out" },
      delay: 0.1, // Small delay so loader has time to start fading
    });

    // Terminal entrance
    tl.from("#hero-terminal", {
      opacity: 0,
      y: 30,
      scale: 0.97,
      duration: 0.7,
    })
      // Animate terminal lines appearing
      .from(
        ".terminal__line:not(.terminal__line--active)",
        {
          opacity: 0,
          x: -10,
          duration: 0.08,
          stagger: 0.2,
          ease: "none",
        },
        "-=0.3"
      )
      // Hero content entrance
      .from(
        "#hero-content",
        {
          opacity: 0,
          y: 40,
          duration: 0.8,
        },
        "+=0.3"
      )
      // Stagger children
      .from(
        "#hero-content > *",
        {
          opacity: 0,
          y: 25,
          stagger: 0.1,
          duration: 0.6,
        },
        "-=0.5"
      );

    // Scroll indicator fades out on scroll
    gsap.to(".hero__scroll-indicator", {
      opacity: 0,
      scrollTrigger: {
        trigger: ".hero",
        start: "top top",
        end: "bottom top",
        scrub: 0.3,
      },
    });
  });
</script>
