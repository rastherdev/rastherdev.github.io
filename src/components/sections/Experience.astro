---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { experience } from "../../data/experience";

interface Props {
  locale: "en" | "es";
}

// Deterministic pseudo commit hash from company name (pure flavor)
function pseudoHash(s: string): string {
  let h = 0;
  for (const c of s) h = (h * 31 + c.charCodeAt(0)) >>> 0;
  return h.toString(16).padStart(7, "0").slice(0, 7);
}

// "1y 6m" — language-neutral, terminal style. Computed at build time;
// "Present" durations refresh on each deploy, which is fine for a static CV.
function duration(start: string, end: string | null): string {
  const s = new Date(start + "-01");
  const e = end ? new Date(end + "-01") : new Date();
  const months =
    (e.getFullYear() - s.getFullYear()) * 12 + (e.getMonth() - s.getMonth());
  const y = Math.floor(months / 12);
  const m = months % 12;
  return [y ? `${y}y` : "", m ? `${m}m` : ""].filter(Boolean).join(" ") || "1m";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;
  const dateLocale = Astro.props.locale === "es" ? "es-MX" : "en-US";
  const fmt = (d: string) =>
    new Date(d + "-01").toLocaleDateString(dateLocale, { month: "short", year: "numeric" });

  return (
    <section class="experience section section--band" id="experience">
      <div class="section__inner">
        <SectionHeading title={dict.experience.heading} />

        <div class="exp-cli" aria-hidden="true">
          <div class="exp-cli__bar">
            <span class="exp-cli__dot exp-cli__dot--red"></span>
            <span class="exp-cli__dot exp-cli__dot--yellow"></span>
            <span class="exp-cli__dot exp-cli__dot--green"></span>
            <span class="exp-cli__title">giovany@dev: ~/career</span>
          </div>
          <p class="exp-cli__line">
            <span class="exp-cli__prompt">$</span> git log --graph --author="Giovany Domínguez"
          </p>
        </div>

        <!-- git-log timeline: branch rail on the left, one "commit" per job -->
        <div class="exp-log">
          <!-- rail in plain HTML: SVG dash/pathLength tricks misrender when the
               svg is stretched with preserveAspectRatio="none" -->
          <div class="exp-log__rail" aria-hidden="true">
            <span class="exp-log__track"></span>
            <span class="exp-log__progress"></span>
            <span class="exp-log__tip"></span>
          </div>

          {experience.map((entry) => (
            <div class="exp-commit">
              <div class={`exp-commit__dot${!entry.endDate ? " exp-commit__dot--head" : ""}`} aria-hidden="true">
                <span class="exp-commit__dot-core"></span>
              </div>

              <article class="exp-card">
                <header class="exp-card__head">
                  <p class="exp-card__meta">
                    <span class="exp-card__label">commit</span>
                    <span class="exp-card__hash" data-hash={pseudoHash(entry.company)}>{pseudoHash(entry.company)}</span>
                    {!entry.endDate && (
                      <span class="exp-card__head-badge">(HEAD → main) · {dict.experience.currentBadge}</span>
                    )}
                  </p>
                  <div class="exp-card__title-row">
                    <h3 class="exp-card__role">{entry.role}</h3>
                    <span class="exp-card__company">@ {entry.company}</span>
                  </div>
                  <p class="exp-card__dates">
                    <i class="fa-regular fa-calendar" aria-hidden="true"></i>
                    {fmt(entry.startDate)} — {entry.endDate ? fmt(entry.endDate) : dict.experience.present}
                    <span class="exp-card__duration">{duration(entry.startDate, entry.endDate)}</span>
                  </p>
                </header>

                <div class="exp-card__grid">
                  <div class="exp-card__col">
                    <h4 class="exp-card__col-title">
                      <i class="fa-solid fa-list-check" aria-hidden="true"></i>
                      {dict.experience.responsibilitiesLabel}
                    </h4>
                    <ul class="exp-card__list">
                      {entry.responsibilities.map((r) => <li>{r}</li>)}
                    </ul>
                  </div>

                  <div class="exp-card__col">
                    <h4 class="exp-card__col-title">
                      <i class="fa-solid fa-trophy" aria-hidden="true"></i>
                      {dict.experience.achievementsLabel}
                    </h4>
                    <ul class="exp-card__list exp-card__list--achievements">
                      {entry.achievements.map((a) => (
                        <li>
                          {a.text.split(/(\d+%)/).map((part) =>
                            /^\d+%$/.test(part)
                              ? <strong class="exp-counter" data-target={parseInt(part)}>{part}</strong>
                              : part
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <footer class="exp-card__stack">
                  {entry.stack.map((tech) => <span class="exp-card__chip">{tech}</span>)}
                </footer>
              </article>
            </div>
          ))}
        </div>
      </div>
    </section>
  );
})()}

<style>
  /* ── git-log terminal window ─────────────────────────── */
  .exp-cli {
    width: fit-content;
    max-width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    margin-bottom: var(--space-2xl);
  }

  .exp-cli__bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.55rem 1rem;
    background: rgba(0, 0, 0, 0.35);
    border-bottom: 1px solid var(--color-border);
  }

  .exp-cli__dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .exp-cli__dot--red { background: #ff5f57; }
  .exp-cli__dot--yellow { background: #febc2e; }
  .exp-cli__dot--green { background: #28c840; }

  .exp-cli__title {
    margin-left: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .exp-cli__line {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-md) var(--space-lg);
  }

  .exp-cli__prompt {
    color: var(--color-code);
  }

  /* ── Log layout: rail + commits ─────────────────────── */
  .exp-log {
    position: relative;
    max-width: 1000px;
    padding-left: 56px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .exp-log__rail {
    position: absolute;
    left: 20px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    transform: translateX(-50%);
  }

  /* dashed track — git-graph vibe */
  .exp-log__track {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      180deg,
      var(--color-border) 0 5px,
      transparent 5px 11px
    );
  }

  /* fills top→bottom via scaleY (compositor-only; animating height would
     force layout + repaint on every scrolled frame) */
  .exp-log__progress {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, var(--color-accent), var(--color-code));
    border-radius: var(--border-radius-full);
    box-shadow: 0 0 8px var(--color-accent-glow);
    transform: scaleY(0);
    transform-origin: top;
    will-change: transform;
  }

  /* glowing pen tip — separate element moved with translateY so the bar's
     scaleY doesn't squash it */
  .exp-log__tip {
    position: absolute;
    top: -4px;
    left: 50%;
    width: 8px;
    height: 8px;
    margin-left: -4px;
    border-radius: 50%;
    background: var(--color-code);
    box-shadow: 0 0 10px rgba(77, 212, 192, 0.9);
    will-change: transform;
  }

  .exp-commit {
    position: relative;
  }

  .exp-commit__dot {
    position: absolute;
    /* center the dot on the rail (padding-left 56 → rail at -36px from card edge) */
    left: -36px;
    top: 26px;
    transform: translateX(-50%);
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 14px var(--color-accent-glow);
    z-index: 1;
  }

  .exp-commit__dot-core {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* Current job: expanding ping ring */
  @media (prefers-reduced-motion: no-preference) {
    .exp-commit__dot--head::after {
      content: "";
      position: absolute;
      inset: -2px;
      border-radius: 50%;
      border: 2px solid var(--color-accent);
      animation: dotPing 2.2s ease-out infinite;
    }
  }

  @keyframes dotPing {
    0% { transform: scale(1); opacity: 0.8; }
    70%, 100% { transform: scale(2.3); opacity: 0; }
  }

  /* ── Commit card ────────────────────────────────────── */
  .exp-card {
    background: linear-gradient(160deg, var(--color-surface-raised), var(--color-surface) 55%);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-xl);
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
  }

  .exp-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top left, var(--color-accent-glow), transparent 60%);
    opacity: 0;
    transition: opacity 0.35s;
    pointer-events: none;
  }

  .exp-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 12px 40px rgba(240, 160, 48, 0.1);
    transform: translateY(-3px);
  }

  .exp-card:hover::before {
    opacity: 1;
  }

  .exp-card__head {
    margin-bottom: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px dashed var(--color-border);
    position: relative;
    z-index: 1;
  }

  .exp-card__meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .exp-card__label {
    color: var(--color-text-muted);
  }

  .exp-card__hash {
    color: var(--color-code);
  }

  .exp-card__head-badge {
    color: var(--color-accent);
  }

  .exp-card__title-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .exp-card__role {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
  }

  .exp-card__company {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--color-accent);
  }

  .exp-card__dates {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .exp-card__duration {
    background: rgba(240, 160, 48, 0.08);
    border: 1px solid rgba(240, 160, 48, 0.2);
    color: var(--color-accent);
    border-radius: var(--border-radius-full);
    padding: 0.15em 0.7em;
  }

  /* ── Content columns ────────────────────────────────── */
  .exp-card__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-xl);
    position: relative;
    z-index: 1;
    margin-bottom: var(--space-lg);
  }

  .exp-card__col-title {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .exp-card__col-title i {
    color: var(--color-code);
  }

  .exp-card__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .exp-card__list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    padding-left: var(--space-md);
    position: relative;
    transition: color 0.3s;
  }

  .exp-card__list li::before {
    content: "❯";
    position: absolute;
    left: 0;
    color: var(--color-border-hover);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    top: 0.3em;
    transition: color 0.3s;
  }

  .exp-card__list li:hover {
    color: var(--color-text);
  }

  .exp-card__list li:hover::before {
    color: var(--color-accent);
  }

  .exp-card__list--achievements li::before {
    content: "★";
    color: rgba(240, 160, 48, 0.4);
  }

  .exp-counter {
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  /* ── Stack chips ────────────────────────────────────── */
  .exp-card__stack {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    position: relative;
    z-index: 1;
  }

  .exp-card__chip {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-code);
    background: rgba(77, 212, 192, 0.06);
    border: 1px solid rgba(77, 212, 192, 0.18);
    border-radius: var(--border-radius-full);
    padding: 0.3em 0.9em;
    transition: border-color 0.25s, box-shadow 0.25s;
  }

  .exp-card__chip:hover {
    border-color: var(--color-code);
    box-shadow: 0 0 12px rgba(77, 212, 192, 0.15);
  }

  /* ── Mobile ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .exp-log {
      padding-left: 36px;
    }

    .exp-log__rail {
      left: 10px;
    }

    .exp-commit__dot {
      left: -26px;
      width: 18px;
      height: 18px;
    }

    .exp-card {
      padding: var(--space-lg);
    }

    .exp-card__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // ── Heading + CLI line ─────────────────────────────
    const tl = gsap.timeline({
      scrollTrigger: { trigger: ".experience", start: "top 65%" },
    });

    tl.from(".experience .section-heading__title", {
      opacity: 0, y: 20, duration: 0.6, ease: "power3.out",
    })
      .from(".experience .section-heading__line", {
        scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out",
      }, "-=0.2")
      .from(".exp-cli", {
        opacity: 0, x: -20, duration: 0.5, ease: "power2.out",
      }, "-=0.2");

    // ── Rail draws as you scroll (scrub, transform-only) ──
    const railScrub = {
      trigger: ".exp-log",
      start: "top 60%",
      end: "bottom 45%",
      scrub: 1,
      invalidateOnRefresh: true,
    };

    gsap.fromTo(".exp-log__progress", { scaleY: 0 }, {
      scaleY: 1,
      ease: "none",
      scrollTrigger: railScrub,
    });

    const rail = document.querySelector<HTMLElement>(".exp-log__rail")!;
    gsap.fromTo(".exp-log__tip", { y: 0 }, {
      y: () => rail.clientHeight,
      ease: "none",
      scrollTrigger: railScrub,
    });

    // ── Each commit reveals on its own trigger ─────────
    document.querySelectorAll<HTMLElement>(".exp-commit").forEach((commit) => {
      const trigger = { trigger: commit, start: "top 72%" };

      gsap.from(commit.querySelector(".exp-card"), {
        opacity: 0, x: -40, duration: 0.7, ease: "power3.out",
        scrollTrigger: trigger,
      });

      gsap.from(commit.querySelector(".exp-commit__dot"), {
        scale: 0, duration: 0.5, ease: "back.out(2.5)",
        scrollTrigger: trigger,
      });

      // Commit hash "types in" (TextPlugin)
      const hashEl = commit.querySelector<HTMLElement>(".exp-card__hash");
      if (hashEl) {
        const hash = hashEl.dataset.hash ?? "";
        ScrollTrigger.create({
          ...trigger,
          once: true,
          onEnter: () => {
            hashEl.textContent = "";
            gsap.to(hashEl, { text: hash, duration: 0.6, ease: "none", delay: 0.2 });
          },
        });
      }

      // List items cascade in
      gsap.from(commit.querySelectorAll(".exp-card__list li"), {
        opacity: 0, x: -14, stagger: 0.05, duration: 0.4, ease: "power2.out",
        scrollTrigger: { trigger: commit, start: "top 65%" },
      });

      // Stack chips pop
      gsap.from(commit.querySelectorAll(".exp-card__chip"), {
        opacity: 0, scale: 0.7, stagger: 0.05, duration: 0.35, ease: "back.out(1.8)",
        scrollTrigger: { trigger: commit, start: "top 60%" },
      });
    });

    // ── Percentages count up ───────────────────────────
    document.querySelectorAll<HTMLElement>(".exp-counter").forEach((el) => {
      const target = parseInt(el.dataset.target ?? "0");
      const state = { v: 0 };
      gsap.to(state, {
        v: target,
        duration: 1.4,
        ease: "power2.out",
        scrollTrigger: { trigger: el, start: "top 85%", once: true },
        onUpdate: () => {
          el.textContent = `${Math.round(state.v)}%`;
        },
      });
    });
  });
</script>
