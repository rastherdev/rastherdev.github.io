---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="about section" id="about">
      <!-- Decorative service-node graph -->
      <div class="about__nodes" id="about-nodes" aria-hidden="true">
        <svg class="about__nodes-svg" viewBox="0 0 800 500" preserveAspectRatio="none">
          <line class="about__edge" x1="120" y1="120" x2="380" y2="80" data-speed="0.7" />
          <line class="about__edge" x1="380" y1="80" x2="650" y2="180" data-speed="0.8" />
          <line class="about__edge" x1="120" y1="120" x2="300" y2="350" data-speed="0.9" />
          <line class="about__edge" x1="650" y1="180" x2="550" y2="380" data-speed="0.75" />
          <line class="about__edge" x1="300" y1="350" x2="550" y2="380" data-speed="0.85" />
          <line class="about__edge" x1="380" y1="80" x2="300" y2="350" data-speed="0.65" />
          <circle class="about__node about__node--lg" cx="120" cy="120" r="12" data-speed="0.6" />
          <circle class="about__node" cx="380" cy="80" r="7" data-speed="0.7" />
          <circle class="about__node about__node--accent" cx="650" cy="180" r="9" data-speed="0.8" />
          <circle class="about__node" cx="300" cy="350" r="6" data-speed="0.85" />
          <circle class="about__node about__node--accent" cx="550" cy="380" r="10" data-speed="0.9" />
          <circle class="about__node about__node--sm" cx="250" cy="60" r="4" data-speed="0.55" />
          <circle class="about__node about__node--sm" cx="720" cy="280" r="3" data-speed="0.95" />
          <circle class="about__node about__node--sm" cx="80" cy="300" r="4" data-speed="0.5" />
        </svg>
      </div>

      <!-- Mouse-follow glow -->
      <div class="about__mouse-glow" id="about-glow" aria-hidden="true"></div>

      <div class="section__inner">
        <SectionHeading title={dict.about.heading} />
        <div class="about__grid">
          <div class="about__bio" data-speed="0.85">
            {dict.about.bio.map((p, i) => <p class="about__paragraph" style={`--i:${i}`}>{p}</p>)}
          </div>
          <div class="about__facts" data-speed="1.15">
            {dict.about.quickFacts.map((f) => (
              <div class="about__fact">
                <span class="about__fact-label">{f.label}</span>
                <span class="about__fact-value">{f.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  );
})()}

<style>
  .about {
    position: relative;
    overflow: hidden;
  }

  /* ── Decorative node graph ───────────────────────────── */
  .about__nodes {
    position: absolute;
    inset: -10%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.25;
  }

  .about__nodes-svg {
    width: 100%;
    height: 100%;
  }

  .about__edge {
    stroke: var(--color-border);
    stroke-width: 1;
    opacity: 0.5;
    stroke-dasharray: 6 4;
    animation: edgePulse 4s ease-in-out infinite;
  }
  .about__edge:nth-child(2) { animation-delay: 0.5s; }
  .about__edge:nth-child(3) { animation-delay: 1s; }
  .about__edge:nth-child(4) { animation-delay: 1.5s; }
  .about__edge:nth-child(5) { animation-delay: 2s; }
  .about__edge:nth-child(6) { animation-delay: 2.5s; }

  @keyframes edgePulse {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.7; }
  }

  .about__node {
    fill: var(--color-border);
    animation: nodeFloat 5s ease-in-out infinite;
  }
  .about__node:nth-child(7) { animation-delay: 0.3s; }
  .about__node:nth-child(8) { animation-delay: 0.8s; }
  .about__node:nth-child(9) { animation-delay: 1.3s; }
  .about__node:nth-child(10) { animation-delay: 1.8s; }
  .about__node:nth-child(11) { animation-delay: 2.3s; }
  .about__node:nth-child(12) { animation-delay: 2.8s; }
  .about__node:nth-child(13) { animation-delay: 3.3s; }
  .about__node:nth-child(14) { animation-delay: 3.8s; }

  .about__node--lg { fill: rgba(240, 160, 48, 0.25); }
  .about__node--accent { fill: var(--color-code); }
  .about__node--sm { fill: var(--color-border); opacity: 0.6; }

  @keyframes nodeFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* ── Mouse-follow glow ───────────────────────────────── */
  .about__mouse-glow {
    position: absolute;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    transform: translate(-50%, -50%);
    transition: opacity 0.3s ease;
  }

  /* ── Layout ──────────────────────────────────────────── */
  .about__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
    position: relative;
    z-index: 2;
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about__paragraph {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--text-base);
    position: relative;
    padding-left: var(--space-md);
    border-left: 1px solid transparent;
    transition: border-color 0.4s ease, color 0.4s ease;
  }

  .about__paragraph:hover {
    border-left-color: var(--color-accent);
    color: var(--color-text);
  }

  .about__facts {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    position: relative;
    overflow: hidden;
  }

  .about__facts::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at 30% 20%, rgba(77, 212, 192, 0.04), transparent 60%);
    pointer-events: none;
  }

  .about__fact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.3s ease;
  }

  .about__fact:hover {
    transform: translateX(4px);
  }

  .about__fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about__fact-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .about__fact-value {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .about__nodes {
      opacity: 0.12;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // ── Section entrance: aggressive opposite stagger ──────
    const tl = gsap.timeline({
      scrollTrigger: { trigger: ".about", start: "top 65%" },
    });

    // Heading scale-in
    tl.from(".about .section-heading__title", {
      opacity: 0, y: 30, scale: 0.95, duration: 0.7, ease: "power3.out",
    })
      .from(".about .section-heading__line", {
        scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out",
      }, "-=0.3")
      // Bio from LEFT
      .from(".about__paragraph", {
        opacity: 0, x: -60, stagger: 0.18, duration: 0.65, ease: "power4.out",
      }, "-=0.1")
      // Facts from RIGHT (overlaps with bio)
      .from(".about__fact", {
        opacity: 0, x: 60, stagger: 0.12, duration: 0.55, ease: "power4.out",
      }, "-=0.9");

    // ── Nodes pop in ──────────────────────────────────────
    gsap.from(".about__node", {
      opacity: 0, scale: 0, stagger: 0.08, duration: 0.5, ease: "back.out(1.7)",
      scrollTrigger: { trigger: ".about__nodes", start: "top 80%" },
    });

    // Edges draw in
    gsap.from(".about__edge", {
      strokeDashoffset: 20, opacity: 0, stagger: 0.1, duration: 0.8, ease: "power2.out",
      scrollTrigger: { trigger: ".about__nodes", start: "top 75%" },
    });

    // ── Mouse-follow glow ──────────────────────────────────
    const glow = document.getElementById("about-glow")!;
    const section = document.querySelector<HTMLElement>(".about")!;

    section.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      gsap.to(glow, {
        left: e.clientX - rect.left,
        top: e.clientY - rect.top,
        opacity: 0.5,
        duration: 0.6,
        ease: "power2.out",
        overwrite: "auto",
      });
    });

    section.addEventListener("mouseleave", () => {
      gsap.to(glow, { opacity: 0, duration: 0.4 });
    });
  });
</script>
