---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";
import { siteConfig } from "../../data/social";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="about section" id="about">
      <div class="section__inner">
        <SectionHeading title={dict.about.heading} />

        <div class="about__grid">
          <div class="about__bio" data-speed="0.9">
            {dict.about.bio.map((paragraph) => (
              <p class="about__paragraph">{paragraph}</p>
            ))}
          </div>

          <div class="about__facts" data-speed="1.05">
            {dict.about.quickFacts.map((fact) => (
              <div class="about__fact">
                <span class="about__fact-label">{fact.label}</span>
                <span class="about__fact-value">{fact.value}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  );
})()}

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about__paragraph {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--text-base);
  }

  .about__facts {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__fact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .about__fact:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .about__fact-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .about__fact-value {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    text-align: right;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: ".about",
        start: "top 70%",
      },
    });

    tl.from(".about .section-heading__title", {
      opacity: 0,
      y: 20,
      duration: 0.6,
      ease: "power3.out",
    })
      .from(
        ".about .section-heading__line",
        { scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out" },
        "-=0.2"
      )
      .from(
        ".about__paragraph",
        { opacity: 0, y: 20, stagger: 0.15, duration: 0.5, ease: "power3.out" },
        "-=0.1"
      )
      .from(
        ".about__fact",
        { opacity: 0, x: 30, stagger: 0.1, duration: 0.4, ease: "power3.out" },
        "-=0.3"
      );
  });
</script>
