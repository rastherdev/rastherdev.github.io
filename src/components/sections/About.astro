---
import SectionHeading from "../ui/SectionHeading.astro";
import en from "../../i18n/en";
import es from "../../i18n/es";

interface Props {
  locale: "en" | "es";
}

// Tech terms auto-highlighted in the bio (same spelling in EN and ES)
const KEYWORDS = ["Laravel", "SaaS", "multi-tenant", "backend", "open-source", "legacy"];
const kwRegex = new RegExp(`(${KEYWORDS.join("|")})`, "gi");
const isKeyword = (part: string) =>
  KEYWORDS.some((k) => k.toLowerCase() === part.toLowerCase());
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;

  return (
    <section class="about section section--band" id="about">
      <!-- Decorative service-node graph -->
      <div class="about__nodes" id="about-nodes" aria-hidden="true">
        <!-- no data-speed on SVG children: per-child parallax forces a full
             SVG repaint on every scroll frame -->
        <svg class="about__nodes-svg" viewBox="0 0 800 500" preserveAspectRatio="none">
          <line class="about__edge" x1="120" y1="120" x2="380" y2="80" />
          <line class="about__edge" x1="380" y1="80" x2="650" y2="180" />
          <line class="about__edge" x1="120" y1="120" x2="300" y2="350" />
          <line class="about__edge" x1="650" y1="180" x2="550" y2="380" />
          <line class="about__edge" x1="300" y1="350" x2="550" y2="380" />
          <line class="about__edge" x1="380" y1="80" x2="300" y2="350" />
          <circle class="about__node about__node--lg" cx="120" cy="120" r="12" />
          <circle class="about__node" cx="380" cy="80" r="7" />
          <circle class="about__node about__node--accent" cx="650" cy="180" r="9" />
          <circle class="about__node" cx="300" cy="350" r="6" />
          <circle class="about__node about__node--accent" cx="550" cy="380" r="10" />
          <circle class="about__node about__node--sm" cx="250" cy="60" r="4" />
          <circle class="about__node about__node--sm" cx="720" cy="280" r="3" />
          <circle class="about__node about__node--sm" cx="80" cy="300" r="4" />
        </svg>
      </div>

      <!-- Mouse-follow glow -->
      <div class="about__mouse-glow" id="about-glow" aria-hidden="true"></div>

      <div class="section__inner">
        <div class="about__panel" id="about-panel">
          <div class="about__panel-beam" aria-hidden="true"><span></span></div>
          <SectionHeading title={dict.about.heading} />
          <!-- no data-speed here: parallax drift would push content outside the bordered panel -->
          <div class="about__grid">
            <div class="about__bio">
              {dict.about.bio.map((p, i) => (
                <p class="about__paragraph" style={`--i:${i}`}>
                  {p.split(kwRegex).map((part) =>
                    isKeyword(part) ? <mark class="about__hl">{part}</mark> : part
                  )}
                </p>
              ))}
            </div>

            <!-- Quick facts as a whoami terminal -->
            <div class="about__facts">
              <div class="about__facts-bar" aria-hidden="true">
                <span class="about__facts-dot about__facts-dot--red"></span>
                <span class="about__facts-dot about__facts-dot--yellow"></span>
                <span class="about__facts-dot about__facts-dot--green"></span>
                <span class="about__facts-title">giovany@dev: ~/whoami</span>
              </div>
              <div class="about__facts-body">
                {dict.about.quickFacts.map((f) => (
                  <div class="about__fact">
                    <span class="about__fact-label">
                      <span class="about__fact-prompt">$</span> {f.label}
                    </span>
                    <span class="about__fact-value">{f.value}</span>
                  </div>
                ))}
                <div class="about__facts-cursorline" aria-hidden="true">
                  <span class="about__fact-prompt">$</span>
                  <span class="about__facts-cursor"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  );
})()}

<style>
  .about {
    position: relative;
    overflow: hidden;
  }

  /* ── Decorative node graph ───────────────────────────── */
  .about__nodes {
    position: absolute;
    inset: -10%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.25;
  }

  .about__nodes-svg {
    width: 100%;
    height: 100%;
  }

  .about__edge {
    stroke: var(--color-border);
    stroke-width: 1;
    opacity: 0.5;
    stroke-dasharray: 6 4;
    animation: edgePulse 4s ease-in-out infinite;
  }
  .about__edge:nth-child(2) { animation-delay: 0.5s; }
  .about__edge:nth-child(3) { animation-delay: 1s; }
  .about__edge:nth-child(4) { animation-delay: 1.5s; }
  .about__edge:nth-child(5) { animation-delay: 2s; }
  .about__edge:nth-child(6) { animation-delay: 2.5s; }

  @keyframes edgePulse {
    0%, 100% { opacity: 0.25; }
    50% { opacity: 0.7; }
  }

  .about__node {
    fill: var(--color-border);
    animation: nodeFloat 5s ease-in-out infinite;
  }
  .about__node:nth-child(7) { animation-delay: 0.3s; }
  .about__node:nth-child(8) { animation-delay: 0.8s; }
  .about__node:nth-child(9) { animation-delay: 1.3s; }
  .about__node:nth-child(10) { animation-delay: 1.8s; }
  .about__node:nth-child(11) { animation-delay: 2.3s; }
  .about__node:nth-child(12) { animation-delay: 2.8s; }
  .about__node:nth-child(13) { animation-delay: 3.3s; }
  .about__node:nth-child(14) { animation-delay: 3.8s; }

  .about__node--lg { fill: rgba(240, 160, 48, 0.25); }
  .about__node--accent { fill: var(--color-code); }
  .about__node--sm { fill: var(--color-border); opacity: 0.6; }

  @keyframes nodeFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  /* ── Mouse-follow glow ───────────────────────────────── */
  /* positioned by GSAP transforms (left/top tweens would force layout) */
  .about__mouse-glow {
    position: absolute;
    top: 0;
    left: 0;
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent-glow), transparent 70%);
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    will-change: transform;
  }

  /* ── Panel: light wash + animated beam border to delimit the section ── */
  .about__panel {
    position: relative;
    z-index: 2;
    border-radius: var(--border-radius-xl);
    border: 1px solid var(--color-border);
    padding: clamp(var(--space-xl), 4vw, var(--space-3xl));
    background: linear-gradient(
      180deg,
      rgba(226, 226, 240, 0.05),
      rgba(226, 226, 240, 0.015) 45%,
      rgba(17, 17, 34, 0.4)
    );
    box-shadow: 0 0 60px rgba(226, 226, 240, 0.03) inset, var(--shadow-lg);
  }

  /* Beam traveling around the panel perimeter. The gradient sits on an
     oversized inner square rotated with transform (compositor-only, painted
     once) — animating the gradient angle itself repaints every frame. */
  .about__panel-beam {
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    -webkit-mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    pointer-events: none;
    overflow: hidden;
  }

  .about__panel-beam span {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 250%;
    aspect-ratio: 1;
    transform: translate(-50%, -50%);
    background: conic-gradient(
      from 0deg,
      transparent 0%,
      transparent 72%,
      var(--color-accent) 86%,
      rgba(226, 226, 240, 0.9) 93%,
      transparent 100%
    );
    animation: beamSpin 7s linear infinite;
    will-change: transform;
  }

  @keyframes beamSpin {
    to {
      transform: translate(-50%, -50%) rotate(1turn);
    }
  }

  /* Soft light spill above the panel edge */
  .about__panel::after {
    content: "";
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(226, 226, 240, 0.35), transparent);
    filter: blur(0.5px);
    pointer-events: none;
  }

  /* ── Layout ──────────────────────────────────────────── */
  .about__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-3xl);
    align-items: start;
    position: relative;
    z-index: 2;
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about__paragraph {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--text-base);
    position: relative;
    padding-left: var(--space-md);
    border-left: 1px solid transparent;
    transition: border-color 0.4s ease, color 0.4s ease;
  }

  .about__paragraph:hover {
    border-left-color: var(--color-accent);
    color: var(--color-text);
  }

  /* Lead paragraph: bigger, brighter, editorial drop cap */
  .about__paragraph:first-of-type {
    font-size: var(--text-lg);
    color: var(--color-text);
  }

  .about__paragraph:first-of-type::first-letter {
    float: left;
    font-family: var(--font-display);
    font-size: 3em;
    line-height: 0.8;
    padding-right: 0.15em;
    color: var(--color-accent);
    font-weight: 700;
  }

  /* Auto-highlighted tech keywords */
  .about__hl {
    background: none;
    color: var(--color-accent);
    font-weight: 500;
    border-bottom: 1px dotted rgba(240, 160, 48, 0.45);
  }

  /* ── Quick facts: whoami terminal ────────────────────── */
  .about__facts {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-xl);
    position: relative;
    overflow: hidden;
  }

  .about__facts::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(ellipse at 30% 20%, rgba(77, 212, 192, 0.04), transparent 60%);
    pointer-events: none;
  }

  .about__facts-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 0.6rem 1rem;
    background: rgba(0, 0, 0, 0.35);
    border-bottom: 1px solid var(--color-border);
  }

  .about__facts-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
  }

  .about__facts-dot--red { background: #ff5f57; }
  .about__facts-dot--yellow { background: #febc2e; }
  .about__facts-dot--green { background: #28c840; }

  .about__facts-title {
    margin-left: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .about__facts-body {
    padding: var(--space-lg) var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__fact {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
    transition: transform 0.3s ease;
  }

  .about__fact:hover {
    transform: translateX(4px);
  }

  .about__fact:last-of-type {
    border-bottom: none;
  }

  .about__fact-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: lowercase;
  }

  .about__fact-prompt {
    color: var(--color-code);
  }

  .about__fact-value {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text);
    text-align: right;
  }

  .about__fact:hover .about__fact-value {
    color: var(--color-accent);
  }

  .about__facts-cursorline {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }

  .about__facts-cursor {
    width: 8px;
    height: 1.1em;
    background: var(--color-code);
    animation: cursorBlink 1.1s steps(1) infinite;
  }

  @keyframes cursorBlink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  /* SVG animations are not GPU-composited — pause them while off-screen
     (the .is-inview class is toggled by an IntersectionObserver) */
  .about:not(.is-inview) .about__edge,
  .about:not(.is-inview) .about__node,
  .about:not(.is-inview) .about__panel-beam span {
    animation-play-state: paused;
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    /* at 0.12 opacity it was barely visible on mobile — not worth the repaints */
    .about__nodes {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from "../../scripts/utils/gsap-setup";

  const mm = gsap.matchMedia();

  mm.add("(prefers-reduced-motion: no-preference)", () => {
    // ── Section entrance: aggressive opposite stagger ──────
    const tl = gsap.timeline({
      scrollTrigger: { trigger: ".about", start: "top 65%", once: true },
    });

    // Panel reveals first, then its content
    tl.from("#about-panel", {
      opacity: 0,
      y: 40,
      scale: 0.985,
      duration: 0.8,
      ease: "power3.out",
    })
      // Heading scale-in
      .from(".about .section-heading__title", {
        opacity: 0, y: 30, scale: 0.95, duration: 0.7, ease: "power3.out",
      }, "-=0.4")
      .from(".about .section-heading__line", {
        scaleX: 0, opacity: 0, duration: 0.5, ease: "power3.out",
      }, "-=0.3")
      // Bio from LEFT
      .from(".about__paragraph", {
        opacity: 0, x: -60, stagger: 0.18, duration: 0.65, ease: "power4.out",
      }, "-=0.1")
      // Facts from RIGHT (overlaps with bio)
      .from(".about__fact", {
        opacity: 0, x: 60, stagger: 0.12, duration: 0.55, ease: "power4.out",
      }, "-=0.9");

    // ── Nodes pop in ──────────────────────────────────────
    gsap.from(".about__node", {
      opacity: 0, scale: 0, stagger: 0.08, duration: 0.5, ease: "back.out(1.7)",
      scrollTrigger: { trigger: ".about__nodes", start: "top 80%", once: true },
    });

    // Edges draw in
    gsap.from(".about__edge", {
      strokeDashoffset: 20, opacity: 0, stagger: 0.1, duration: 0.8, ease: "power2.out",
      scrollTrigger: { trigger: ".about__nodes", start: "top 75%", once: true },
    });

    // ── Mouse-follow glow (transforms only) ────────────────
    const glow = document.getElementById("about-glow")!;
    const section = document.querySelector<HTMLElement>(".about")!;

    gsap.set(glow, { xPercent: -50, yPercent: -50 });
    const glowX = gsap.quickTo(glow, "x", { duration: 0.6, ease: "power2.out" });
    const glowY = gsap.quickTo(glow, "y", { duration: 0.6, ease: "power2.out" });
    let glowVisible = false;

    section.addEventListener("mousemove", (e: MouseEvent) => {
      const rect = section.getBoundingClientRect();
      glowX(e.clientX - rect.left);
      glowY(e.clientY - rect.top);
      if (!glowVisible) {
        glowVisible = true;
        gsap.to(glow, { opacity: 0.5, duration: 0.3, overwrite: "auto" });
      }
    });

    section.addEventListener("mouseleave", () => {
      glowVisible = false;
      gsap.to(glow, { opacity: 0, duration: 0.4, overwrite: "auto" });
    });
  });

  // Pause the constellation + panel-beam animations while off-screen
  const aboutEl = document.querySelector<HTMLElement>(".about")!;
  new IntersectionObserver((entries) =>
    entries.forEach((entry) => aboutEl.classList.toggle("is-inview", entry.isIntersecting))
  ).observe(aboutEl);
</script>
