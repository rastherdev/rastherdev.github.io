---
import en from "../../i18n/en";
import es from "../../i18n/es";
import { resumeUrl } from "../../data/social";

interface Props {
  locale: "en" | "es";
}
---

{(() => {
  const dict = Astro.props.locale === "en" ? en : es;
  const otherLocale = Astro.props.locale === "en" ? "es" : "en";
  // Determine the alternate URL: English lives at /, Spanish at /es/
  const currentPath = Astro.url.pathname;
  const alternatePath = Astro.props.locale === "en"
    ? `/es${currentPath}`
    : currentPath.replace(/^\/es/, "") || "/";

  return (
    <header class="nav" id="nav">
      <div class="nav__inner">
        <a href="/" class="nav__logo" aria-label="Home">
          <span class="nav__logo-bracket">&lt;</span>
          <span class="nav__logo-text">GD</span>
          <span class="nav__logo-bracket"> /&gt;</span>
        </a>

        <span class="nav__path" id="nav-path" aria-hidden="true">~/</span>

        <nav class="nav__links" id="nav-links" aria-label="Main navigation">
          <a href="#about" class="nav__link" data-section="about" data-num="01" style="--i:0">{dict.nav.about}</a>
          <a href="#skills" class="nav__link" data-section="skills" data-num="02" style="--i:1">{dict.nav.skills}</a>
          <a href="#experience" class="nav__link" data-section="experience" data-num="03" style="--i:2">{dict.nav.experience}</a>
          <a href="#projects" class="nav__link" data-section="projects" data-num="04" style="--i:3">{dict.nav.projects}</a>
          <a href="#contact" class="nav__link" data-section="contact" data-num="05" style="--i:4">{dict.nav.contact}</a>
          <a href={resumeUrl} class="nav__link nav__link--cv" style="--i:5" download>{dict.nav.downloadCv}</a>
        </nav>

        <div class="nav__actions">
          <a href={alternatePath} class="nav__locale" aria-label={`Switch to ${otherLocale === "en" ? "English" : "Español"}`}>
            {otherLocale === "en" ? "EN" : "ES"}
          </a>
          <button class="nav__burger" id="nav-burger" aria-label="Toggle menu" aria-expanded="false" type="button">
            <span class="nav__burger-line"></span>
            <span class="nav__burger-line"></span>
            <span class="nav__burger-line"></span>
          </button>
        </div>
      </div>
      <span class="nav__progress" id="nav-progress" aria-hidden="true"></span>
    </header>
  );
})()}

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    height: var(--nav-height);
    display: flex;
    align-items: center;
    transition: box-shadow var(--transition-base);
  }

  /* Blur lives on a pseudo-element: backdrop-filter on .nav itself would turn
     the header into the containing block for the fixed mobile overlay,
     squashing it into the 64px bar. */
  .nav::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(8, 8, 15, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .nav.is-scrolled::before {
    opacity: 1;
  }

  /* Mobile: full-width backdrop blur re-filters the page on every scrolled
     frame — a slightly more opaque solid bar reads the same */
  @media (max-width: 768px) {
    .nav::before {
      background: rgba(8, 8, 15, 0.92);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }

  .nav.is-scrolled {
    box-shadow: 0 1px 0 var(--color-border);
  }

  .nav__inner {
    max-width: var(--max-width);
    width: 100%;
    margin-inline: auto;
    padding-inline: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    position: relative;
  }

  /* Current-section breadcrumb chip — mobile only */
  .nav__path {
    display: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
    background: rgba(240, 160, 48, 0.07);
    border: 1px solid rgba(240, 160, 48, 0.25);
    border-radius: var(--border-radius-full);
    padding: 0.2em 0.8em;
    white-space: nowrap;
    transition: opacity var(--transition-base);
  }

  @media (max-width: 768px) {
    .nav__path {
      display: block;
    }
  }

  /* Scroll progress hairline — shown wherever the desktop rail isn't */
  .nav__progress {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-code));
    transform: scaleX(0);
    transform-origin: left;
    pointer-events: none;
  }

  /* hidden only where the desktop section rail takes over */
  @media (min-width: 1400px) {
    .nav__progress {
      display: none;
    }
  }

  .nav__logo {
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 2px;
    transition: color var(--transition-fast);
  }

  .nav__logo:hover {
    color: var(--color-accent);
  }

  .nav__logo-bracket {
    color: var(--color-text-muted);
    font-weight: 400;
  }

  .nav__logo-text {
    color: var(--color-accent);
  }

  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav__link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav__link:hover,
  .nav__link.is-active {
    color: var(--color-accent);
  }

  .nav__link--cv {
    border: 1px solid var(--color-accent);
    padding: 0.35em 1em;
    border-radius: var(--border-radius-full);
    color: var(--color-accent);
  }

  .nav__link--cv:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .nav__locale {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 0.3em 0.7em;
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-full);
    transition: all var(--transition-fast);
  }

  .nav__locale:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    z-index: 10;
  }

  .nav__burger-line {
    width: 24px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  /* Mobile nav open */
  .nav__burger.is-open .nav__burger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav__burger.is-open .nav__burger-line:nth-child(2) {
    opacity: 0;
  }
  .nav__burger.is-open .nav__burger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 768px) {
    .nav__links {
      position: fixed;
      inset: 0;
      background:
        radial-gradient(circle at 85% 12%, rgba(240, 160, 48, 0.09), transparent 45%),
        radial-gradient(circle at 12% 88%, rgba(77, 212, 192, 0.08), transparent 45%),
        rgba(8, 8, 15, 0.96);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: var(--space-xl);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
    }

    .nav__links.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .nav__link {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: 700;
      color: var(--color-text);
      display: flex;
      align-items: baseline;
      gap: var(--space-md);
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.45s ease, transform 0.45s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    /* editorial index numbers */
    .nav__link[data-num]::before {
      content: attr(data-num);
      font-family: var(--font-mono);
      font-size: var(--text-sm);
      font-weight: 400;
      color: var(--color-accent);
    }

    /* staggered entrance when the menu opens */
    .nav__links.is-open .nav__link {
      opacity: 1;
      transform: none;
      transition-delay: calc(100ms + var(--i, 0) * 70ms);
    }

    /* resume button lives only in the desktop navbar */
    .nav__link--cv {
      display: none;
    }

    .nav__burger {
      display: flex;
    }

    .nav__burger.is-open .nav__burger-line {
      background: var(--color-accent);
    }
  }
</style>

<script>
  const nav = document.getElementById("nav")!;
  const burger = document.getElementById("nav-burger")!;
  const navLinks = document.getElementById("nav-links")!;

  // Scroll-aware background blur + progress hairline
  // (uses ScrollSmoother exposed by BaseLayout)
  const progressEl = document.getElementById("nav-progress");

  // Cache layout reads: reading scrollHeight every frame forces layout.
  // Recomputed only on resize and once after the loader settles.
  let maxScroll = 0;
  function refreshMaxScroll() {
    maxScroll = document.documentElement.scrollHeight - window.innerHeight;
  }
  refreshMaxScroll();
  window.addEventListener("resize", refreshMaxScroll);
  window.addEventListener("load", refreshMaxScroll);

  let lastScrolled = false;
  let lastScaleX = -1;

  function updateNavBg() {
    const smoother = (window as any).__smoother;
    const scrollY = smoother?.scrollTop() ?? window.scrollY;

    const scrolled = scrollY > 20;
    if (scrolled !== lastScrolled) {
      lastScrolled = scrolled;
      nav.classList.toggle("is-scrolled", scrolled);
    }

    if (progressEl && maxScroll > 0) {
      const scaleX = Math.min(scrollY / maxScroll, 1);
      // skip the DOM write when nothing changed (idle frames)
      if (Math.abs(scaleX - lastScaleX) > 0.001) {
        lastScaleX = scaleX;
        progressEl.style.transform = `scaleX(${scaleX})`;
      }
    }

    requestAnimationFrame(updateNavBg);
  }
  requestAnimationFrame(updateNavBg);

  // Active section tracking via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>("section[id]");
  const links = document.querySelectorAll<HTMLAnchorElement>(".nav__link[data-section]");

  const pathEl = document.getElementById("nav-path");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          links.forEach((link) => {
            link.classList.toggle("is-active", link.dataset.section === entry.target.id);
          });
          if (pathEl) {
            pathEl.textContent = entry.target.id === "top" ? "~/" : `~/${entry.target.id}`;
          }
        }
      });
    },
    { rootMargin: "-40% 0px -55% 0px", threshold: 0 }
  );

  sections.forEach((s) => observer.observe(s));

  // Anchor links: use ScrollSmoother for smooth scroll
  links.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = link.getAttribute("href")!;
      const target = document.querySelector(targetId) as HTMLElement;
      if (!target) return;

      const smoother = (window as any).__smoother;
      if (smoother) {
        smoother.scrollTo(target, true, "top 4rem");
      } else {
        target.scrollIntoView({ behavior: "smooth" });
      }

      navLinks.classList.remove("is-open");
      burger.classList.remove("is-open");
      burger.setAttribute("aria-expanded", "false");
    });
  });

  // Mobile menu toggle
  burger.addEventListener("click", () => {
    const isOpen = navLinks.classList.toggle("is-open");
    burger.classList.toggle("is-open", isOpen);
    burger.setAttribute("aria-expanded", String(isOpen));
  });
</script>
