---
import Nav from "../components/layout/Nav.astro";
import Footer from "../components/layout/Footer.astro";
import Loader from "../components/ui/Loader.astro";
import CustomCursor from "../components/ui/CustomCursor.astro";
import SectionNav from "../components/ui/SectionNav.astro";
import ScrollTop from "../components/ui/ScrollTop.astro";
import en from "../i18n/en";
import es from "../i18n/es";
import "../styles/global.css";

interface Props {
  locale: "en" | "es";
  title?: string;
  description?: string;
  /** Desktop scrollspy rail — only for pages that have the landing sections. */
  sectionNav?: boolean;
}
---

<!doctype html>
<html lang={Astro.props.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={Astro.props.description ?? "Giovany Domínguez — Laravel Backend Developer. Portfolio & CV."} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{Astro.props.title ?? "Giovany Domínguez — Laravel Backend Developer"}</title>

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- FontAwesome Icons -->
    <script src="https://kit.fontawesome.com/0bacbba471.js" crossorigin="anonymous"></script>

    <!-- Prevent FOUC — hide smooth-wrapper until loader finishes. Loader is outside so it stays visible -->
    <style is:inline>
      html:not(.loader-done) #smooth-wrapper {
        opacity: 0;
      }
      html.loader-done #smooth-wrapper {
        opacity: 1;
        transition: opacity 0.3s ease;
      }
    </style>
  </head>
  <body>
    <Loader />
    <CustomCursor />
    <Nav locale={Astro.props.locale} />
    {Astro.props.sectionNav && <SectionNav />}
    <ScrollTop label={(Astro.props.locale === "en" ? en : es).footer.backToTop} />
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <main>
          <slot />
        </main>
        <Footer locale={Astro.props.locale} />
      </div>
    </div>
  </body>
</html>

<script>
  import { gsap, ScrollTrigger, ScrollSmoother } from "../scripts/utils/gsap-setup";

  // ── ScrollSmoother ──────────────────────────────────────
  // Touch scroll stays native: smoothTouch/normalizeScroll take mobile
  // scrolling off the compositor and drive it through JS — the main source
  // of mobile jank. Desktop keeps the smoothed feel.
  const isFinePointer = window.matchMedia("(pointer: fine)").matches;

  const smoother = ScrollSmoother.create({
    wrapper: "#smooth-wrapper",
    content: "#smooth-content",
    smooth: 1.2,
    effects: true,
    smoothTouch: false,
    normalizeScroll: isFinePointer,
    ignoreMobileResize: true,
  });

  // Expose smoother globally so Nav can use it for anchor links
  (window as any).__smoother = smoother;

  // Route ALL in-page anchors through the smoother: with normalizeScroll,
  // native hash jumps desync scroll position from the content transform and
  // ScrollTriggers never fire (sections stay at opacity 0 — black screen).
  // Components with their own handlers (Nav, SectionNav) preventDefault first
  // and are skipped here.
  document.addEventListener("click", (e) => {
    if (e.defaultPrevented) return;
    const link = (e.target as HTMLElement).closest?.('a[href^="#"]') as HTMLAnchorElement | null;
    if (!link) return;
    const target = document.querySelector<HTMLElement>(link.getAttribute("href")!);
    if (!target) return;
    e.preventDefault();
    smoother.scrollTo(target, true, "top 72px");
  });

  // ── Loader sequence ────────────────────────────────────
  async function initLoader() {
    const loaderEl = document.getElementById("loader");
    if (!loaderEl) return;

    // Wait for loader animation to signal ready
    await new Promise<void>((resolve) => {
      if (document.documentElement.classList.contains("loader-ready")) {
        resolve();
      } else {
        const observer = new MutationObserver(() => {
          if (document.documentElement.classList.contains("loader-ready")) {
            observer.disconnect();
            resolve();
          }
        });
        observer.observe(document.documentElement, { attributes: true, attributeFilter: ["class"] });
        // Fallback: resolve after 2s
        setTimeout(() => { observer.disconnect(); resolve(); }, 2500);
      }
    });

    // Hide loader with animation
    const loaderAnim = (window as any).__loader;
    if (loaderAnim?.hide) {
      await loaderAnim.hide();
    } else {
      loaderEl.style.opacity = "0";
      loaderEl.style.pointerEvents = "none";
      await new Promise((r) => setTimeout(r, 400));
    }

    // Reveal page
    document.documentElement.classList.add("loader-done");

    // Remove loader from DOM
    loaderEl.remove();

    // Refresh ScrollTrigger after layout settles
    requestAnimationFrame(() => {
      ScrollTrigger.refresh();

      // Deep links (/#projects): redo the browser's native hash jump through
      // the smoother so triggers fire and content actually reveals
      if (location.hash) {
        const target = document.querySelector<HTMLElement>(location.hash);
        if (target) smoother.scrollTo(target, false, "top 72px");
      }
    });
  }

  initLoader();

  // ── Language switch support ───────────────────────────
  // Re-show loader on navigation (Astro View Transitions or full page nav)
  document.addEventListener("astro:before-swap", () => {
    // Create a fresh loader overlay for the transition
    const overlay = document.createElement("div");
    overlay.id = "loader";
    overlay.className = "loader";
    overlay.setAttribute("aria-hidden", "true");
    overlay.innerHTML = `
      <div class="loader__content">
        <div class="loader__terminal">
          <div class="loader__line"><span class="loader__prompt">$</span><span class="loader__cmd">switching language...</span></div>
        </div>
        <div class="loader__bar">
          <div class="loader__bar-fill" id="loader-bar"></div>
        </div>
      </div>`;
    overlay.style.opacity = "0";
    document.body.appendChild(overlay);

    gsap.to(overlay, {
      opacity: 1,
      duration: 0.2,
      ease: "power2.out",
      onComplete: () => {
        gsap.to("#loader-bar", { width: "100%", duration: 0.8, ease: "power2.inOut" });
      },
    });
  });

  // Mark current page for ScrollTrigger cleanup on navigation
  document.addEventListener("astro:after-swap", () => {
    ScrollTrigger.refresh();
  });
</script>
